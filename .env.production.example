# MyBizTools Production Environment Variables
# Copy this file to .env and fill in the values

# ============ REQUIRED - CHANGE THESE ============

# Database URL (PostgreSQL recommended for production)
DATABASE_URL=postgresql://user:password@localhost:5432/mybiztools

# JWT Secret - Generate a secure random string (min 32 chars)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secure-jwt-secret-change-this

# API Key for internal services
# Generate with: openssl rand -hex 32
API_KEY=your-secure-api-key-change-this

# Frontend URL (your production domain)
FRONTEND_URL=https://yourdomain.com

# ============ EMAIL CONFIGURATION (Resend) ============

# Resend API Key (get from https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxx

# From email (must be from verified domain in Resend)
# 1. Add your domain at https://resend.com/domains
# 2. Verify DNS records
# 3. Use your verified domain below
FROM_EMAIL=MyBizTools <noreply@yourdomain.com>

# ============ OPTIONAL ============

# Server configuration
PORT=3001
HOST=0.0.0.0
NODE_ENV=production

# JWT expiration
JWT_EXPIRES_IN=7d

# Logging
LOG_LEVEL=info

# ============ PAYMENT GATEWAYS ============

# Paystack (Nigeria)
PAYSTACK_SECRET_KEY=sk_live_xxxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxxx

# Flutterwave
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxxx
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxx

# ============ SMS SERVICE (Termii) ============

# Termii is used for SMS only (email is handled by Resend)
TERMII_API_KEY=your-termii-api-key
TERMII_SENDER_ID=MyBizTools

# ============ AI SERVICES ============

# Anthropic Claude API for DEDA AI
ANTHROPIC_API_KEY=sk-ant-xxxxx
