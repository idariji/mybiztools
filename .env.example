# MyBizTools - Environment Configuration
# Copy this file to .env.local and fill in your credentials

# ========== API CONFIGURATION ==========
# Backend API URL (handles email via Resend, authentication, etc.)
# Development: http://localhost:3001
# Production: your-backend-url.com
VITE_API_URL=http://localhost:3001

# API Key for backend authentication
VITE_API_KEY=mybiztools-dev-key-change-in-production

# ========== TERMII SMS API ==========
# Note: Termii is used for SMS only. Email is handled by Resend on the backend.
# Get your credentials from: https://termii.com

# Base URL (do not modify)
VITE_TERMII_BASE_URL=https://v3.api.termii.com

# Your Termii API Key
VITE_TERMII_API_KEY=your-termii-api-key

# Your Termii Secret API Key (for additional security features)
VITE_TERMII_SECRET_KEY=your-termii-secret-key

# Sender ID for SMS (customizable, must be registered with Termii)
VITE_TERMII_SENDER_ID=MyBizTools

# SMS Channel (generic, dnd, whatsapp)
VITE_TERMII_SMS_CHANNEL=generic
