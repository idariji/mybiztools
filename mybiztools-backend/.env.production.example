# MyBizTools Backend - Production Environment Template
# Copy this file to .env and fill in your production credentials
# NEVER commit the actual .env file to version control!
#
# Generate secure secrets with:
#   JWT_SECRET: openssl rand -hex 64
#   API_KEY: openssl rand -hex 32
#   DB PASSWORD: openssl rand -base64 24

# ============ REQUIRED - MUST CHANGE BEFORE DEPLOYMENT ============

# Database URL (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://mybiztools_user:GENERATE_SECURE_PASSWORD@localhost:5432/mybiztools?schema=public"

# JWT Secret - MUST be unique and secure (min 64 characters)
JWT_SECRET=GENERATE_WITH_openssl_rand_hex_64

# Frontend URL (your production domain with HTTPS)
FRONTEND_URL=https://mybiztools.ng

# ============ EMAIL (Resend - Required) ============

# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_YOUR_PRODUCTION_API_KEY

# From email (must match verified domain in Resend)
FROM_EMAIL=MyBizTools <noreply@mybiztools.ng>

# ============ SMS (Termii) ============

# Get API key from: https://termii.com
TERMII_API_KEY=YOUR_TERMII_LIVE_API_KEY
TERMII_SENDER_ID=MyBizTools

# ============ PAYMENT GATEWAY (Monnify) ============

# Get LIVE keys from: https://app.monnify.com/developer
MONNIFY_API_KEY=MK_PROD_xxxxx
MONNIFY_SECRET_KEY=YOUR_MONNIFY_SECRET
MONNIFY_CONTRACT_CODE=YOUR_CONTRACT_CODE
MONNIFY_BASE_URL=https://api.monnify.com

# ============ AI (Claude API - Optional) ============

# Get API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ============ SERVER CONFIGURATION ============

PORT=3001
HOST=0.0.0.0
NODE_ENV=production

# JWT Expiration
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# File Upload
UPLOAD_DIR=./uploads

# Logging Level (error, warn, info, debug)
LOG_LEVEL=info

# ============ CLOUD DEPLOYMENT (Optional) ============

# For Google Cloud Run, PORT is automatically set to 8080
# PORT=8080

# Cloud SQL Connection (if using Google Cloud SQL)
# DATABASE_URL="postgresql://user:pass@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE"
