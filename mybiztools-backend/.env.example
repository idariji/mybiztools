# MyBizTools Backend - Environment Template
# Copy this file to .env and fill in your credentials

# ========== SECURITY ==========
# API Key for authentication (change this in production!)
API_KEY=mybiztools-dev-key-change-in-production

# ========== EMAIL CONFIGURATION (Resend) ==========
# Get your API key from: https://resend.com/api-keys
# Free tier: 3,000 emails/month, 100 emails/day
RESEND_API_KEY=re_xxxxxxxxxx

# From email address (use resend.dev for testing, your domain for production)
# For testing: MyBizTools <onboarding@resend.dev>
# For production: MyBizTools <noreply@yourdomain.com>
FROM_EMAIL=MyBizTools <onboarding@resend.dev>

# ========== SERVER CONFIGURATION ==========
PORT=3001
HOST=localhost
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# ========== JWT CONFIGURATION ==========
JWT_SECRET=mybiztools-jwt-secret-change-in-production-use-long-random-string
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ========== DATABASE ==========
# SQLite for local development (no server needed)
DATABASE_URL="file:./dev.db"

# For production with PostgreSQL, uncomment and update:
# DATABASE_URL="postgresql://username:password@your-vps-ip:5432/mybiztools?schema=public"

# ========== SMS CONFIGURATION (Termii) ==========
# Get your API key from: https://termii.com
TERMII_API_KEY=your-termii-api-key
TERMII_SENDER_ID=MyBizTools

# ========== PAYMENT GATEWAY (Monnify) ==========
# Get these from https://app.monnify.com/developer
MONNIFY_API_KEY=your-monnify-api-key
MONNIFY_SECRET_KEY=your-monnify-secret-key
MONNIFY_CONTRACT_CODE=your-contract-code
MONNIFY_BASE_URL=https://sandbox.monnify.com

# ========== AI CONFIGURATION (Claude API) ==========
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ========== FILE UPLOAD ==========
UPLOAD_DIR=./uploads

# ========== LOGGING ==========
LOG_LEVEL=info
