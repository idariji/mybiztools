// Prisma Schema for MyBizTools Backend
// Run migrations after updating:
// npx prisma migrate dev --name <migration-name>
// npx prisma generate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

// ============================================================================
// USER MODEL
// ============================================================================

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  password            String
  firstName           String?
  lastName            String?
  businessName        String?
  phone               String?
  avatarUrl           String?

  // Email verification
  emailVerified       Boolean   @default(false)
  verificationToken   String?   @unique
  verificationExpires DateTime?

  // OTP
  otpCode             String?
  otpExpires          DateTime?
  otpPurpose          String?   // "email_verification" | "password_reset"

  // Subscription
  subscription        Subscription?
  currentPlan         String    @default("free")
  subscriptionStatus  String    @default("active")

  // Metadata
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  lastLoginAt         DateTime?
  ipAddress           String?
  country             String?
  deviceInfo          String?

  // Relations
  payments            Payment[]
  auditLogs           AdminAuditLog[]
  overrides           PromotionalOverride[]
  usageTracking       UsageTracking?
  abuseReports        AbuseReport[]

  @@index([email])
  @@index([subscriptionStatus])
  @@index([currentPlan])
  @@index([verificationToken])
  @@index([otpCode])
}

// ============================================================================
// SUBSCRIPTION MODELS
// ============================================================================

model Subscription {
  id                   String    @id @default(uuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  planName             String    // "free" | "pro" | "enterprise"
  status               String    @default("active")

  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  trialEndDate         DateTime?
  expiresAt            DateTime?
  cancelledAt          DateTime?
  cancelledReason      String?

  // Billing (in Naira kobo)
  mrrValue             BigInt    @default(0)
  annualValue          BigInt    @default(0)
  isPaused             Boolean   @default(false)
  autoRenew            Boolean   @default(true)

  paymentMethodId      String?
  lastPaymentId        String?

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  manualChanges        ManualSubscriptionChange[]

  @@index([planName])
  @@index([status])
  @@index([currentPeriodEnd])
}

// ============================================================================
// PAYMENT MODELS
// ============================================================================

model Payment {
  id                 String    @id @default(uuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId     String?

  amount             BigInt    // In Naira kobo
  currency           String    @default("NGN")
  status             String    // "succeeded" | "failed" | "pending" | "refunded"

  stripePaymentId    String?   @unique
  stripeInvoiceId    String?

  billingPeriodStart DateTime?
  billingPeriodEnd   DateTime?

  failureReason      String?
  retryCount         Int       @default(0)
  nextRetryAt        DateTime?
  maxRetriesReached  Boolean   @default(false)

  refundedAmount     BigInt    @default(0)
  refundReason       String?
  refundedAt         DateTime?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  refundLogs         RefundLog[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([stripePaymentId])
}

model RefundLog {
  id          String   @id @default(uuid())
  paymentId   String
  payment     Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  amount      BigInt
  reason      String
  adminId     String
  adminName   String

  processedAt DateTime @default(now())

  @@index([paymentId])
}

// ============================================================================
// SUBSCRIPTION MANAGEMENT MODELS
// ============================================================================

model ManualSubscriptionChange {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  userId         String

  adminId        String
  adminName      String
  adminRole      String

  action         String    // "upgrade" | "downgrade" | "suspend" | "reactivate" | "extend"
  fromPlan       String?
  toPlan         String?

  effectiveDate  DateTime
  reason         String
  notes          String?

  status         String    @default("pending")
  approvedAt     DateTime?
  completedAt    DateTime?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
  @@index([adminId])
  @@index([action])
}

model PromotionalOverride {
  id                 String   @id @default(uuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  overrideType       String   // "free_promo" | "discount" | "plan_upgrade" | "feature_unlock" | "comp_account"
  planOverride       String?
  discountPercentage Float?
  discountAmount     BigInt?
  specificFeatures   Json?

  startDate          DateTime
  endDate            DateTime
  isActive           Boolean  @default(true)

  reason             String
  appliedBy          String

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
  @@index([isActive])
  @@index([endDate])
}

// ============================================================================
// USAGE TRACKING
// ============================================================================

model UsageTracking {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan           String
  featureUsage   Json     // { [feature]: { used, limit, resetDate } }

  lastResetDate  DateTime @default(now())
  nextResetDate  DateTime

  isOverQuota    Boolean  @default(false)
  warningsCount  Int      @default(0)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([plan])
  @@index([isOverQuota])
}

// ============================================================================
// ABUSE & SECURITY
// ============================================================================

model AbuseReport {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  reportType  String   // "quota_abuse" | "payment_fraud" | "api_abuse" | "free_account_spam" | "ai_abuse" | "deletion_loops"
  severity    String   // "low" | "medium" | "high" | "critical"

  description String
  evidence    Json?

  status      String    @default("pending")
  flaggedAt   DateTime  @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?

  actionTaken  String?  // "suspended" | "warned" | "dismissed" | "overridden"
  actionReason String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([severity])
  @@index([status])
}

// ============================================================================
// ADMIN MODELS
// ============================================================================

model AdminAuditLog {
  id           String  @id @default(uuid())

  adminId      String
  adminName    String
  adminRole    String

  targetUserId String?
  targetUser   User?   @relation(fields: [targetUserId], references: [id], onDelete: SetNull)

  action       String  // "create" | "read" | "update" | "delete"
  resource     String
  resourceId   String

  changes      Json?
  reason       String?

  ipAddress    String?
  userAgent    String?

  createdAt    DateTime @default(now())

  @@index([adminId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@index([targetUserId])
}

model AdminRole {
  id          String   @id @default(uuid())
  name        String   @unique
  level       Int      // 1-4 hierarchy

  permissions Json     // JSON array of permission strings

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Admin {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  name        String
  role        String   @default("viewer") // "super_admin" | "billing_admin" | "support_admin" | "viewer"

  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastLoginAt DateTime?

  @@index([email])
  @@index([role])
}

// ============================================================================
// DOCUMENT STORAGE
// ============================================================================

model Document {
  id             String   @id @default(uuid())
  userId         String

  name           String
  originalName   String
  mimeType       String
  size           BigInt
  storagePath    String
  storageType    String   @default("local") // "local" | "s3" | "cloudinary"

  category       String   @default("other") // "invoice" | "receipt" | "contract" | "report" | "other"
  tags           Json?
  description    String?

  isPublic       Boolean  @default(false)
  downloadCount  Int      @default(0)
  lastAccessedAt DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([category])
  @@index([createdAt])
}

// ============================================================================
// BUDGET & EXPENSE TRACKING
// ============================================================================

model Budget {
  id             String    @id @default(uuid())
  userId         String

  name           String
  amount         BigInt    // In Naira kobo
  period         String    // "monthly" | "quarterly" | "yearly" | "custom"
  category       String    // "marketing" | "operations" | "salary" | "utilities" | "inventory" | "other"

  startDate      DateTime
  endDate        DateTime

  spentAmount    BigInt    @default(0)
  isActive       Boolean   @default(true)

  alertThreshold Int       @default(80)
  alertSent      Boolean   @default(false)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  expenses       Expense[]

  @@index([userId])
  @@index([category])
  @@index([isActive])
}

model Expense {
  id                 String   @id @default(uuid())
  userId             String
  budgetId           String?
  budget             Budget?  @relation(fields: [budgetId], references: [id], onDelete: SetNull)

  amount             BigInt
  currency           String   @default("NGN")
  description        String
  category           String

  receiptUrl         String?
  receiptDocumentId  String?

  paymentMethod      String?  // "cash" | "transfer" | "card" | "mobile"
  vendor             String?

  expenseDate        DateTime
  isRecurring        Boolean  @default(false)
  recurringFrequency String?  // "daily" | "weekly" | "monthly"

  status             String   @default("approved") // "pending" | "approved" | "rejected"
  approvedBy         String?
  approvedAt         DateTime?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
  @@index([budgetId])
  @@index([category])
  @@index([expenseDate])
  @@index([status])
}

// ============================================================================
// CONTACTS / CLIENTS
// ============================================================================

model Contact {
  id              String   @id @default(uuid())
  userId          String

  name            String
  email           String?
  phone           String?
  company         String?
  jobTitle        String?

  type            String   @default("customer") // "customer" | "supplier" | "partner" | "lead" | "other"

  address         String?
  city            String?
  state           String?
  country         String?  @default("Nigeria")
  postalCode      String?

  taxId           String?
  website         String?

  notes           String?
  tags            Json?

  isActive        Boolean  @default(true)
  lastContactedAt DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  invoices        Invoice[]

  @@index([userId])
  @@index([type])
  @@index([isActive])
  @@index([email])
}

model Invoice {
  id               String   @id @default(uuid())
  userId           String
  contactId        String?
  contact          Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  invoiceNumber    String

  subtotal         BigInt
  taxAmount        BigInt   @default(0)
  discountAmount   BigInt   @default(0)
  total            BigInt
  currency         String   @default("NGN")

  status           String   @default("draft") // "draft" | "sent" | "viewed" | "paid" | "overdue" | "cancelled"

  issueDate        DateTime
  dueDate          DateTime
  paidDate         DateTime?

  paymentMethod    String?
  paymentReference String?

  notes            String?
  terms            String?
  documentUrl      String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items            InvoiceItem[]

  @@unique([userId, invoiceNumber])
  @@index([userId])
  @@index([contactId])
  @@index([status])
  @@index([dueDate])
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  description String
  quantity    Int
  unitPrice   BigInt
  amount      BigInt

  createdAt   DateTime @default(now())

  @@index([invoiceId])
}

// ============================================================================
// QUOTATION
// ============================================================================

model Quotation {
  id              String   @id @default(uuid())
  userId          String

  quotationNumber String

  clientName      String
  clientEmail     String?
  clientPhone     String?
  clientAddress   String?

  subtotal        BigInt
  taxAmount       BigInt   @default(0)
  discountAmount  BigInt   @default(0)
  total           BigInt
  currency        String   @default("NGN")

  status          String   @default("draft") // "draft" | "sent" | "accepted" | "rejected" | "expired"

  issueDate       DateTime
  validUntil      DateTime

  notes           String?
  terms           String?

  publicLink      String?  @unique
  publicLinkExpires DateTime?

  documentData    Json?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items           QuotationItem[]

  @@unique([userId, quotationNumber])
  @@index([userId])
  @@index([status])
  @@index([publicLink])
}

model QuotationItem {
  id           String    @id @default(uuid())
  quotationId  String
  quotation    Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  description  String
  quantity     Int
  unitPrice    BigInt
  amount       BigInt

  createdAt    DateTime  @default(now())

  @@index([quotationId])
}

// ============================================================================
// RECEIPT
// ============================================================================

model Receipt {
  id               String   @id @default(uuid())
  userId           String

  receiptNumber    String

  customerName     String
  customerEmail    String?
  customerPhone    String?

  subtotal         BigInt
  taxAmount        BigInt   @default(0)
  total            BigInt
  currency         String   @default("NGN")

  paymentMethod    String?
  paymentReference String?

  receiptDate      DateTime

  notes            String?
  documentData     Json?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items            ReceiptItem[]

  @@unique([userId, receiptNumber])
  @@index([userId])
  @@index([receiptDate])
}

model ReceiptItem {
  id          String   @id @default(uuid())
  receiptId   String
  receipt     Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  description String
  quantity    Int
  unitPrice   BigInt
  amount      BigInt

  createdAt   DateTime @default(now())

  @@index([receiptId])
}

// ============================================================================
// PAYSLIP
// ============================================================================

model Payslip {
  id                  String   @id @default(uuid())
  userId              String

  payslipNumber       String

  employeeName        String
  employeeId          String?
  employeeDepartment  String?
  employeePosition    String?

  payPeriodStart      DateTime
  payPeriodEnd        DateTime
  paymentDate         DateTime

  // Earnings (in Naira kobo)
  basicSalary         BigInt
  housingAllowance    BigInt   @default(0)
  transportAllowance  BigInt   @default(0)
  otherAllowances     BigInt   @default(0)
  bonus               BigInt   @default(0)
  overtime            BigInt   @default(0)
  grossEarnings       BigInt

  // Deductions (in Naira kobo)
  payeTax             BigInt   @default(0)
  pension             BigInt   @default(0)
  nhf                 BigInt   @default(0)
  loans               BigInt   @default(0)
  otherDeductions     BigInt   @default(0)
  totalDeductions     BigInt

  netPay              BigInt
  currency            String   @default("NGN")

  documentData        Json?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([userId, payslipNumber])
  @@index([userId])
  @@index([paymentDate])
}

// ============================================================================
// SOCIAL MEDIA PLANNER
// ============================================================================

model SocialPost {
  id           String   @id @default(uuid())
  userId       String

  content      String
  mediaUrls    Json?

  platforms    Json     // ["twitter", "facebook", "instagram", "linkedin"]

  scheduledAt  DateTime?
  publishedAt  DateTime?
  status       String   @default("draft") // "draft" | "scheduled" | "published" | "failed"

  likes        Int      @default(0)
  shares       Int      @default(0)
  comments     Int      @default(0)
  reach        Int      @default(0)

  errorMessage String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([scheduledAt])
}

// ============================================================================
// AI CHAT (DEDA)
// ============================================================================

model ChatConversation {
  id           String   @id @default(uuid())
  userId       String

  title        String?
  context      String?

  messageCount Int      @default(0)
  tokenUsage   Int      @default(0)

  isArchived   Boolean  @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  messages     ChatMessage[]

  @@index([userId])
  @@index([isArchived])
}

model ChatMessage {
  id             String           @id @default(uuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role           String   // "user" | "assistant" | "system"
  content        String

  tokensUsed     Int      @default(0)
  feedback       String?  // "helpful" | "not_helpful"

  createdAt      DateTime @default(now())

  @@index([conversationId])
  @@index([createdAt])
}

// ============================================================================
// SUPPORT TICKETS
// ============================================================================

model SupportTicket {
  id              String   @id @default(uuid())
  userId          String

  ticketNumber    String   @unique
  subject         String
  message         String

  customerName    String
  customerEmail   String
  customerPhone   String?

  channel         String   @default("email") // "email" | "whatsapp" | "sms"

  status          String   @default("open") // "open" | "in_progress" | "resolved" | "closed"
  priority        String   @default("medium") // "low" | "medium" | "high" | "urgent"

  assignedTo      String?
  assignedName    String?

  firstResponseAt DateTime?
  resolvedAt      DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  responses       SupportTicketResponse[]

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([channel])
  @@index([assignedTo])
}

model SupportTicketResponse {
  id          String        @id @default(uuid())
  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  message     String
  channel     String   // "email" | "whatsapp" | "sms"

  senderType  String   // "admin" | "customer"
  senderId    String?
  senderName  String

  delivered   Boolean  @default(false)
  deliveredAt DateTime?

  createdAt   DateTime @default(now())

  @@index([ticketId])
  @@index([senderType])
}